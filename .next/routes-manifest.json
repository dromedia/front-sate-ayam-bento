{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/backend/[...path]",
      "regex": "^/api/backend/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/backend/(?<nxtPpath>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/customer",
      "regex": "^/customer(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/customer(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/kasir",
      "regex": "^/kasir(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/kasir(?:/)?$"
    },
    {
      "page": "/laporan",
      "regex": "^/laporan(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/laporan(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/menu",
      "regex": "^/menu(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/menu(?:/)?$"
    },
    {
      "page": "/order-online",
      "regex": "^/order\\-online(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/order\\-online(?:/)?$"
    },
    {
      "page": "/pengaturan",
      "regex": "^/pengaturan(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pengaturan(?:/)?$"
    },
    {
      "page": "/pengeluaran",
      "regex": "^/pengeluaran(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pengeluaran(?:/)?$"
    },
    {
      "page": "/transaksi",
      "regex": "^/transaksi(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/transaksi(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}